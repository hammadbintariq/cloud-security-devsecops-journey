              "privilegeLevel": "",
              "threats": [
                {
                  "id": "f7222b7c-8091-4da2-a1aa-6008537f1a7b",
                  "title": "API Request Spoofing & Credential Stuffing",
                  "status": "Open",
                  "severity": "TBD",
                  "type": "Spoofing",
                  "description": "An attacker intercepts or crafts malicious requests to the Fintech API Gateway pretending to be a legitimate Customer, leading to unauthorized account access or payment execution.",
                  "mitigation": "Implement robust OAuth 2.0 / OIDC authentication, mandatory Multi-Factor Authentication (MFA), and strict API rate limiting/throttling at the Gateway.",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 2,
                  "score": ""
                },
                {
                  "id": "10503be5-a7b4-4e14-8af9-63fc1df9df9f",
                  "title": "Payment Parameter Manipulation in Transit",
                  "status": "Open",
                  "severity": "TBD",
                  "type": "Tampering",
                  "description": "An attacker alters the payment details (e.g., changing the destination account or increasing the amount) in the data stream between the Customer and the Fintech API Gateway.",
                  "mitigation": "Enforce TLS 1.3 for all communications crossing the trust boundary. Implement payload signing (e.g., JSON Web Signatures) to verify data integrity before processing.",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 3,
                  "score": ""
                },
                {
                  "id": "d3c19cc2-5cb6-4d21-8651-62470f2ec89f",
                  "title": "SQL/NoSQL Injection via Payment Fields",
                  "status": "Open",
                  "severity": "TBD",
                  "type": "Information disclosure",
                  "description": "Malicious Payloads passed through payment fields bypass validation at the Gateway and hit the Payment Processor, allowing unauthorized read access to sensitive financial records in the Transaction DB",
                  "mitigation": "Enforce strict input validation (allow-listing) at the API Gateway. Use parameterized queries / Prepared Statements in the Payment Processor, and encrypt sensitive DB columns at rest.",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 4,
                  "score": ""
                },
                {
                  "id": "d46e3e97-d870-41e8-bac1-027c21dd5a95",
                  "title": "Card Testing & Velocity Fraud",
                  "status": "Open",
                  "severity": "TBD",
                  "type": "Spoofing",
                  "description": "Fraudsters use automated scripts to rapidly test lists of stolen credit card numbers against the Payment Processor via the API to see which accounts are active.",
                  "mitigation": "Implement behavioral biometrics, advanced device fingerprinting, and fraud-detection velocity checks (e.g., blocking an IP or account after $X$ failed payment attempts within a minute).",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 5,
                  "score": ""
                }
              ],
